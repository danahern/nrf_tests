 *
 * Minimal DT overlay for the native_sim mbox_pse84 ztest. Instantiates
 * a vendor interrupt controller (required for non-ARM arches so that
 * `interrupts = <N P>` has a parent) and a single mbox controller
 * exposing two channels — one per direction.
 */

/ {
	intc: interrupt-controller@f03f00 {
		compatible = "vnd,intc";
		#address-cells = <0>;
		#interrupt-cells = <2>;
		interrupt-controller;
		reg = <0x00f03f00 0x0100>;
	};

	mbox_test: mbox@40220000 {
		compatible = "infineon,pse84-mbox";
		reg = <0x40220000 0x10000>;
		interrupts = <1 1>;
		interrupt-parent = <&intc>;
		channels-used = <8 9>;
		intr-index = <0>;
		#mbox-cells = <1>;
		status = "okay";
	};
};
