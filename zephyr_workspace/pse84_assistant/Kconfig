# pse84_assistant app-level Kconfig.
#
# Only exposes knobs that are purely app-layer. Board / subsystem config
# goes in prj.conf / prj_*.conf.

menu "pse84_assistant app"

# Phase 1b: sprite-sheet playback vs. procedural animations.
#
# SPRITES reads LZ4-compressed RGB565 frames generated by
# tools/video_to_sprites.py from the real cartoon mp4 sources. It needs
# ~11 MiB of read-only asset storage (tier A, 800x480) or ~3 MiB
# (tier B, 400x240 + 2x zoom) plus a 768 KB RAM framebuffer.
#
# PROCEDURAL is the pre-Phase-1b LVGL widget animation path (orb /
# VU bars / spinner / typing label). It's kept because:
#   - native_sim has no 800x480 display and asset bytes inflate the
#     simulator image for no visual benefit,
#   - mps3/corstone300/an547 QEMU is displayless (CONFIG_LVGL=n).
#
# Default is SPRITES on the PSE84 kit, PROCEDURAL everywhere else.
config APP_ANIMATION_SPRITES
	bool "Phase 1b branded sprite animations"
	depends on LVGL
	default y if BOARD_KIT_PSE84_EVAL
	default n
	help
	  Enable LZ4-decoded RGB565 sprite-sheet playback for the four
	  assist states. Requires regenerated assets under
	  zephyr_workspace/pse84_assistant/assets/.

config APP_ANIMATION_SPRITES_TIER_B
	bool "Tier B (400x240 + 2x render zoom)"
	depends on APP_ANIMATION_SPRITES
	default n
	help
	  Signals the runtime to apply lv_image_set_scale(512) so the
	  smaller 400x240 frames fill an 800x480 panel. Flip this on
	  only if assets were regenerated with --force-tier B.

config APP_ANIMATION_PROCEDURAL
	bool "Procedural LVGL widget animations (fallback)"
	depends on LVGL
	default y if !APP_ANIMATION_SPRITES
	default n
	help
	  Keep the orb / bars / spinner / typing label animations (ui.c).
	  Exactly one of SPRITES / PROCEDURAL should be enabled at a time;
	  the default pair above matches that constraint.

config APP_SNAPSHOT
	bool "Enable LVGL → PPM snapshot capture"
	default n
	depends on LVGL && BOARD_NATIVE_SIM
	select LV_USE_SNAPSHOT
	help
	  When enabled, main() runs a snapshot-capture sequence instead of
	  the normal interactive loop: it cycles through all four assist
	  states, lets each animation settle for a few frames, writes a
	  binary PPM file of lv_screen_active() per state to /tmp/snapshots,
	  then calls nsi_exit(0). Intended to be driven from
	  tools/capture_snapshots.sh which post-processes the PPMs into
	  PNGs committed to the repo.

endmenu

source "Kconfig.zephyr"
