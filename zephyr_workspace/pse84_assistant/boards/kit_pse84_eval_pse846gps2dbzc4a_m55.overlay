#include <zephyr/dt-bindings/display/panel.h>

/*
 * Extend the M55 XIP partition to 24 MB to hold the Phase 1b branded
 * sprite assets (~11 MiB at tier A 800x480, LZ4-compressed — see
 * assets/TIER_LOG.md) alongside the app text + LVGL + libopus. The
 * 58 MB octal-NOR XIP aperture at 0x60100000 has plenty of headroom;
 * 24 MB leaves ~34 MB for future phases. Safe because the M55 is loaded
 * by Cy_SysEnableCM55() directly from this region and is not
 * mcuboot-signed, so no slot-size math changes are needed in the
 * signing pipeline.
 */
&m55_xip {
	reg = <0x60500000 DT_SIZE_M(40)>;
};

/* I2C on SCB0 — used by the Waveshare 4.3" panel MCU at 0x45 */
&p8_0_scb0_i2c_scl {
	drive-open-drain;
	input-enable;
};

&p8_1_scb0_i2c_sda {
	drive-open-drain;
	input-enable;
};

&peri0_group1_16bit_1 {
	status = "okay";
	clock-div = <32>;
};

i2c0: &scb0 {
	compatible = "infineon,i2c";
	status = "okay";
	clock-frequency = <100000>;
	#address-cells = <1>;
	#size-cells = <0>;
	clocks = <&peri0_group1_16bit_1>;
	pinctrl-0 = <&p8_0_scb0_i2c_scl &p8_1_scb0_i2c_sda>;
	pinctrl-names = "default";

	waveshare_4p3: waveshare_4p3@45 {
		compatible = "waveshare,dsi-4p3-mcu";
		reg = <0x45>;
		/* default-brightness falls through to binding default (128 = 50%) */
		/* Panel MCU needs DSI link up before it responds on I2C;
		 * let the GFXSS driver trigger init via device_init() after
		 * its own Cy_GFXSS_Init and a stabilization delay.
		 */
		zephyr,deferred-init;
		status = "okay";
	};
};

/* GFXSS display controller — 800x480 Waveshare 4.3" panel.
 * Uses stride-pixels = 832 so RGB565 rows are 128-byte aligned for the
 * DC DMA; the panel's bridge chip crops the tail pixels. The framebuffer
 * lives in the board's socmem_fb SOCMEM region.
 *
 * NOTE: the actual gfxss node declaration is below, re-rooted under
 * &soc to work around the SoC dtsi placing it as a child of the PDM
 * controller (see the /delete-node/ &gfxss; block). The properties
 * here would previously extend the upstream node; Phase 2 moved them
 * into the re-declared node for a single source of truth.
 */

/ {
	chosen {
		zephyr,display = &gfxss;
	};

	/*
	 * Phase 1b: 1 MiB scratch region in SOCMEM for the sprite playback
	 * framebuffer (800*480*2 = 768000 bytes for tier A). Placed at the
	 * 1 MiB aligned slot immediately following socmem_fb (0x26240000 +
	 * 0x100000 = 0x26340000). The M55 linker does not own SOCMEM, so
	 * we point a Zephyr memory-region at it and use DT_REG_ADDR() from
	 * src/sprites.c to place the static scratch buffer via
	 * Z_GENERIC_SECTION.
	 */
	reserved-memory {
		socmem_sprite: memory@26340000 {
			compatible = "zephyr,memory-region", "mmio-sram";
			reg = <0x26340000 DT_SIZE_K(1024)>;
			zephyr,memory-region = "SOCMEM_SPRITE";
		};
	};
};

&gpio_prt20 {
	status = "okay";
};

&gpio_prt21 {
	status = "okay";
};

/*
 * Phase 2: PDM microphone capture (mono, 16 kHz, 16-bit).
 *
 * Mirrors the in-tree sample at
 * zephyr/samples/drivers/audio/dmic/boards/kit_pse84_eval_pse846gps2dbzc4a_m55.overlay —
 * PDM controller 1 (channels 2/3) on pdm3 (p8_5 clk / p8_6 data), clocked
 * from peri1_group1_16_5bit_2 via clk_hf7. We only enable channel 2 (left)
 * for mono; channel 3 stays disabled. `use-alt-io` on ch2 routes the
 * data line to the pdm3 alternate pin (p8_6) per ROUTE_CTL.
 */
&clk_hf7 {
	status = "okay";
	source-path = <IFX_CLK_HF_IN_CLKPATH3>;
};

&peri1_group1_16_5bit_2 {
	status = "okay";
	clock-div = <2>;
	div-frac-value = <7>;
};

&p8_5_pdm3_pdm_clk {
	drive-strength = "half";
	drive-push-pull;
};

&p8_6_pdm3_pdm_data {
	drive-strength = "half";
	input-enable;
};

&dma0 {
	status = "okay";
};

/*
 * The SoC dtsi places gfxss@44800000 as a child of pdm@44400000 (dmic0),
 * which is fine when dmic0 is disabled but the dmic_infineon driver
 * iterates DT_FOREACH_CHILD_STATUS_OKAY expecting every enabled child
 * to have a `channel` property — gfxss has none, so the build fails.
 *
 * Fix: delete gfxss from under dmic0 and re-declare it at the same
 * address under &soc directly. All references via DT_NODELABEL(gfxss)
 * keep resolving because the label survives the move.
 */
/delete-node/ &gfxss;

/ {
	soc {
		gfxss: gfxss@44800000 {
		compatible = "infineon,pse84-gfxss";
		reg = <0x44800000 0x10000>;
		status = "okay";
		width = <800>;
		height = <480>;
		stride-pixels = <832>;
		pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
		framebuffer = <&socmem_fb>;
		num-lanes = <1>;
		per-lane-mbps = <810>;
		pixel-clock-khz = <33768>;
		hsync-width = <10>;
		hfp = <210>;
		hbp = <20>;
		vsync-width = <5>;
		vfp = <20>;
		vbp = <20>;
		};
	};
};

dmic_dev: &dmic0 {
	pinctrl-0 = <&p8_5_pdm3_pdm_clk &p8_6_pdm3_pdm_data>;
	pinctrl-names = "default";
	clocks = <&peri1_group1_16_5bit_2>;
	status = "okay";

	dmas = <&dma0 0>;
	dma-names = "rx";
};

&dmic0_ch2 {
	status = "okay";
	use-alt-io;
	/*
	 * fir0-enable MANDATORY at 16 kHz (DT binding note). fir1-scale
	 * default is 15 (right-shift 15 → signal divided by 32768). That
	 * aggressive attenuation was likely hiding real-but-faint mic
	 * signal under the filter noise floor on this kit. Dropping to
	 * 9 amplifies by 64x — enough to clear the floor for a low-SPL
	 * onboard MEMS mic.
	 */
	fir0-enable;
	fir1-scale = <0>;  /* max gain: no right-shift at all */
};

/*
 * Add 50 ms software debounce to sw0 — the kit's default gpio-keys
 * parent node in kit_pse84_eval_common.dtsi has no
 * `debounce-interval-ms`, so every physical press RELEASE generates a
 * burst of release/press edges. First press works because the initial
 * contact (press) is typically clean; when the user finally releases
 * after a 2 s hold, bounce fires multiple release→press→release cycles
 * rapidly. Each bounce-press starts a NEW 2 s capture which is then
 * ended by the next bounce-release, producing the 4-5 spurious ~100 ms
 * captures the user observed. debounce-interval-ms is a property of
 * the gpio_keys *parent* compatible, not individual children.
 */
/ {
	gpio_keys {
		debounce-interval-ms = <50>;
	};
};

/*
 * ch3 must be enabled too even though we only consume ch2 in mono.
 * The Infineon PDM engine configures ch2/ch3 as a stereo pair sharing
 * CLK+DATA; leaving ch3 disabled produces "silence with a click" —
 * a one-shot transient at capture start, then no sampling. Matches
 * upstream zephyr/samples/drivers/audio/dmic/boards/kit_pse84_eval*
 * which also enables both. req_num_chan=1 + PDM_CHAN_LEFT in audio.c
 * still routes only ch2 data to the ring buffer.
 */
&dmic0_ch3 {
	status = "okay";
};

/*
 * Phase 2: console UART baud for the 64 KB hex PCM dump path (2 s mono
 * 16-bit @ 16 kHz → 64 KB raw → ~128 KB as 2-char-per-byte hex + line
 * breaks). 460800 finishes the dump in ~3 s — fast enough, and proven
 * clean end-to-end on the KitProg3 CDC bridge. 921600 was attempted
 * first but showed ~45 % byte-level corruption during sustained bursts,
 * consistent with the CAT1 SCB UART driver accepting up to 10 % baud
 * drift (IFX_UART_MAX_BAUD_PERCENT_DIFFERENCE in uart_infineon_pdl.c)
 * plus KitProg3's own CDC quirks. If Phase 4 L2CAP throughput probes
 * need higher rates, tune peri0_group1_16bit_0 clock-div for an
 * integer divider at the target baud, or switch to an RTT backend.
 */
&uart2 {
	current-speed = <460800>;
};

/*
 * Phase 0b.2: instantiate the PSE84 mailbox driver (drivers/mbox/mbox_pse84.c)
 * for the M55 side of the Phase 0b IPC. Reuses CY_IPC_CHAN_USER + 1 for the
 * M55 doorbell receive side (M33 writes, M55 reads). NVIC line 46 =
 * m55appcpuss_interrupts_ipc_dpslp_0_IRQn per
 * zephyrproject/modules/hal/infineon/mtb-template-pse8xxgp/files/devices/
 * include/pse846gps2dbzc4a.h. Channel pair decision + intr-index mapping
 * documented in dts/bindings/mbox/infineon,pse84-mbox.yaml.
 *
 * No runtime wiring yet — no ipc_service client consumes this mbox.
 * Driver just init-probes at boot so we can see it come up cleanly
 * before Phase 0b.3 lands the M33 app + Phase 0b.4 wires ipc_service.
 */
/ {
	soc {
		pse84_mbox: mbox@441d0000 {
			compatible = "infineon,pse84-mbox";
			reg = <0x441d0000 0x1000>;
			interrupts = <46 3>;
			channels-used = <9 10>;   /* CY_IPC_CHAN_USER + {0,1} */
			intr-index = <0>;
			#mbox-cells = <1>;
			status = "okay";
		};
	};

	/*
	 * Phase 0b.3/4: ipc_service icmsg endpoint using the shared-memory
	 * regions pinned in docs/ipc_design.md — 4 KiB each at 0x240fe000
	 * (M33 -> M55, RX from our perspective) and 0x240ff000 (M55 -> M33,
	 * TX). mboxes reference the two channels listed in pse84_mbox's
	 * channels-used array (cell 0 = CY_IPC_CHAN_USER for signal/notify
	 * toward M33, cell 1 = CY_IPC_CHAN_USER+1 for receive-from-M33).
	 * At boot the subsystem initialises and waits for the peer; M33 app
	 * image lands in Phase 0b.5+.
	 */
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;

		ipc_rx: memory@240fe000 {
			reg = <0x240fe000 0x1000>;
		};
		ipc_tx: memory@240ff000 {
			reg = <0x240ff000 0x1000>;
		};
	};

	/* `ipc0` label is reserved by the PSE84 SoC DTSI for the IPC0
	 * peripheral; our ipc_service endpoint uses a distinct label
	 * (assistant_ipc0) to avoid the collision.
	 */
	ipc {
		assistant_ipc0: assistant_ipc0 {
			compatible = "zephyr,ipc-icmsg";
			tx-region = <&ipc_tx>;
			rx-region = <&ipc_rx>;
			mboxes = <&pse84_mbox 1>, <&pse84_mbox 0>;
			mbox-names = "rx", "tx";
			status = "okay";
		};
	};
};

/*
 * Phase 4 — BLE HCI UART to the onboard CYW55513 AIROC combo.
 *
 * Pins P10.0-P10.3 on SCB4 are the HCI UART (H4, HW flow control).
 * gpio_prt11 P0 is BT_REG_ON. The standard pattern comes from
 * kit_pse84_ai_m55.dts (M55-primary sibling kit that uses the same
 * radio). Speeds match the defaults baked into the CYW55513 firmware
 * download flow (115200 for both FW download and operation).
 *
 * Zephyr BLE runs on M55 here rather than the "canonical" M33 split
 * because the M33 flash iteration is currently blocked (extended-boot
 * parks CM33 regardless of what we flash into RRAM — see
 * project_pse84_m33_flash_slot_mystery.md). Putting the BT stack on
 * M55 unblocks Phase 4 progress at the cost of using a bit more of
 * M55's cycles; revisit once the M33 boot path is resolved.
 */
&peri0_group1_16_5bit_0 {
	status = "okay";
	clock-div = <1>;
};

&gpio_prt11 {
	status = "okay";
};

&gpio_prt10 {
	status = "okay";
};

uart4: &scb4 {
	compatible = "infineon,uart";
	status = "okay";

	current-speed = <115200>;

	clocks = <&peri0_group1_16_5bit_0>;

	pinctrl-0 = <&p10_1_scb4_uart_tx &p10_0_scb4_uart_rx
		     &p10_3_scb4_uart_rts &p10_2_scb4_uart_cts>;
	pinctrl-names = "default";

	hw-flow-control;

	bt_hci_uart: bt_hci_uart {
		compatible = "zephyr,bt-hci-uart";

		cyw55513 {
			status = "okay";
			compatible = "infineon,bt-hci-uart";
			bt-reg-on-gpios = <&gpio_prt11 0 GPIO_ACTIVE_HIGH>;
			fw-download-speed = <115200>;
			hci-operation-speed = <115200>;
		};
	};
};

&p10_1_scb4_uart_tx {
	drive-push-pull;
};

&p10_0_scb4_uart_rx {
	input-enable;
};

&p10_3_scb4_uart_rts {
	drive-push-pull;
};

&p10_2_scb4_uart_cts {
	input-enable;
};

/ {
	chosen {
		zephyr,bt-hci = &bt_hci_uart;
	};
};
