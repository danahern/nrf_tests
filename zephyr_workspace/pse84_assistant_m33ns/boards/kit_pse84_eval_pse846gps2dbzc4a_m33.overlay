/*
 * PSE84 Voice Assistant — M33 companion board overlay.
 *
 * Mirrors sysbuild/enable_cm55.overlay from pse84_assistant: route
 * CLK_HF12 to CLKPATH0 (DPLL_LP0 = 400 MHz) divided by 16 to yield
 * 25 MHz — close enough to the external 24 MHz oscillator spec for
 * the MIPI-DSI D-PHY PLL reference on CLKPATH4.
 *
 * Without this override CLK_HF12 defaults to the CLKPATH4 source that
 * is not running, so HF12 = 0 Hz and Cy_MIPI_DSI_Dphy_Enable() spins
 * forever in its unbounded PHY_LOCK polling loop.
 */

#include <zephyr/dt-bindings/clock/ifx_clock_source_common.h>

&clk_hf12 {
	source-path = <IFX_CLK_HF_IN_CLKPATH0>;
	clock-div = <IFX_CLK_HF_DIVIDE_BY_16>;
	status = "okay";
};

/*
 * M55 overrides uart2 to 460800 baud for the Phase 2 PCM hex dump.
 * Both cores share uart2 as console (hardware contention: whichever
 * core writes first wins; occasional interleaved bytes are expected).
 * Match the baud here so M33 printk output is at least decodable by
 * the host serial monitor. Longer-term fix: route M33 console to a
 * different SCB or forward M33 logs to M55 via ipc_service.
 */
&uart2 {
	current-speed = <460800>;
};

/*
 * Phase 0b.8: M33 side of the assistant ipc_service endpoint.
 *
 * Mirrors pse84_assistant/boards/.../m55.overlay's mbox + ipc nodes
 * but with TX/RX channels swapped so the icmsg ring matches:
 *   M55 TX (ch9) → M33 RX (ch9)
 *   M55 RX (ch10) → M33 TX (ch10)
 *
 * NVIC IRQ 1 = m33syscpuss_interrupts_ipc_dpslp_0_IRQn (DeepSleep
 * table) per modules/hal/infineon/zephyr-ifx-cycfg/.../device_headers/
 * cy_device_headers_ns.h. intr-index=0 mirrors the M55 side so each
 * CPU listens on its own per-CPU intr struct 0.
 *
 * `reg` is informational only — the driver dispatches via Cy_IPC_Drv_*
 * which knows the correct per-CPU MMIO alias (0x422a0000 NS / secure
 * alias for M33 vs 0x441d0000 for M55).
 *
 * Shared-memory regions are pinned at the same physical addresses as
 * the M55 side; both cores see the same SOCMEM, so labels swap roles
 * (M33's RX = the buffer M55 writes to = ipc_tx, and vice versa).
 */
/ {
	soc {
		pse84_mbox: mbox@422a0000 {
			compatible = "infineon,pse84-mbox";
			reg = <0x422a0000 0x1000>;
			interrupts = <1 3>;
			channels-used = <10 9>;
			intr-index = <0>;
			#mbox-cells = <1>;
			status = "okay";
		};
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;

		ipc_rx: memory@240ff000 {
			reg = <0x240ff000 0x1000>;
		};
		ipc_tx: memory@240fe000 {
			reg = <0x240fe000 0x1000>;
		};
	};

	ipc {
		assistant_ipc0: assistant_ipc0 {
			compatible = "zephyr,ipc-icmsg";
			tx-region = <&ipc_tx>;
			rx-region = <&ipc_rx>;
			mboxes = <&pse84_mbox 1>, <&pse84_mbox 0>;
			mbox-names = "rx", "tx";
			status = "okay";
		};
	};
};
